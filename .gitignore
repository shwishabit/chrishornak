# .gitignore

# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage
/test-results
/tests/screenshots

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
Thumbs.db
/images/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env*.local
.env

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# lighthouse reports
lighthouse-*.json

# audit-tool test harness output (regenerable via `npx tsx scripts/test-real-sites.ts`)
scripts/test-output/
scripts/test-output-*/
